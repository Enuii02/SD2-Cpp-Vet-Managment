{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "shell",
            "label": "C/C++: g++ build all files",
            "command": "pwsh",
            "args": [
                "-Command",
                "$env:PATH = 'C:\\msys64\\ucrt64\\bin;' + $env:PATH; g++.exe -fdiagnostics-color=always -g -o main.exe main.cpp menu.cpp features.cpp profiles.cpp && echo 'Build completed successfully!'"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build all source files with g++",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false
            }
        }
    ],
    "version": "2.0.0"
}